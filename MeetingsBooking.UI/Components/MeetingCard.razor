@using MeetingsBooking.Shared.Dtos
<div class="meeting-list">

    @foreach (var Meeting in Meetings)
    {
        <MeetingCard Meeting="meeting" />
        <div class="meeting-card">

            <div class="meeting-header">

                <div>

                    <div class="meeting-date">

                        📅
                        @Meeting.MeetingDate.ToString("dddd, dd MMM yyyy")

                    </div>

                    <h3>
                        @Meeting.MeetingDetails.MeetingTitle
                    </h3>

                </div>

            </div>

            <div class="meeting-info">

                <div>

                    🕑

                    @Meeting.StartTime

                </div>

                <div>

                    ⏱

                    @Meeting.DurationInMinutes Minutes

                </div>

                <div>

                    🌍

                    @Meeting.TimeZone

                </div>

            </div>

            @* <div class="meeting-actions">

                <button @onclick="() => ToggleDetails(Meeting)">

                    @(Meeting.IsExpanded ? "Hide Details" : "View Details")

                </button>

                <button>

                    Reschedule

                </button>

                <button class="danger">
                    Cancel
                </button>
                <a href="@GetMeetingUrl(Meeting.Id)"
                   target="_blank"
                   class="join-button @(CanJoinMeeting(Meeting) ? "" : "disabled")">
                    <i class="fas fa-video"></i>
                    Join Meeting
                </a>

            </div> *@
            <div class="meeting-actions">

            <div class="left-actions">

                <button @onclick="() => ToggleDetails(Meeting)"
                        class="primary-btn">

                    <i class="bi bi-eye-fill"></i>
                    @(Meeting.IsExpanded ? "Hide Details" : "View Details")

                </button>

                <button class="warning-btn">

                    <i class="bi bi-pencil-square"></i>
                    Reschedule

                </button>

                <button class="danger-btn">

                    <i class="bi bi-x-circle-fill"></i>
                    Cancel

                </button>

            </div>
            <div class="right-actions">

                <button class="join-btn"
                        disabled="@(!CanJoinMeeting(Meeting))">
                    <i class="bi bi-camera-video-fill"></i>
                    Join Meeting

                </button>

            </div>

</div>
            @if (Meeting.IsExpanded)
            {
                <div class="meeting-details">

                    <h4>Reason</h4>

                    <p>

                        @Meeting.MeetingDetails.MeetingReason

                    </p>

                    <h4>

                        Discussion Topics

                    </h4>

                    <ul>

                        @foreach (var topic in Meeting.MeetingDetails.DiscussionTopics)
                        {
                            <li>@topic</li>
                        }

                    </ul>

                    <h4>

                        Additional Notes

                    </h4>

                    <p>
                        @Meeting.MeetingDetails.AdditionalNotes

                    </p>

                </div>
            }

        </div>
    }
</div>
@code {

    private Guid? ExpandedMeetingId;
    [Parameter]
    public List<MeetingResponseDto> Meetings { get; set; }

    private bool ShowDetails;

    private void ToggleDetails(MeetingResponseDto meeting)
    {
        meeting.IsExpanded = !meeting.IsExpanded;
    }
    public string JoinMeetingUrl { get; set; } = string.Empty;
    private string GetMeetingUrl(Guid id)
    {
        return $"https://meet.myapp.com/{id}";
    }
    private bool CanJoinMeeting(MeetingResponseDto meeting)
{
    var start = meeting.MeetingDate.Date +
                meeting.StartTime.ToTimeSpan();

    var joinFrom = start.AddMinutes(-10);

    var meetingEnds = start.AddMinutes(
        meeting.DurationInMinutes);

    return DateTime.Now >= joinFrom
        && DateTime.Now <= meetingEnds;
}
}